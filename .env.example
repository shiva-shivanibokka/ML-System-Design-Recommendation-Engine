# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# PostgreSQL credentials
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_USER=recsys
POSTGRES_DB=recsys

# Grafana admin password
GRAFANA_PASSWORD=change_me_in_production

# Optional overrides (defaults work for local docker-compose)
# POSTGRES_HOST=postgres
# REDIS_HOST=redis
# KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# MLFLOW_TRACKING_URI=http://mlflow:5001

# For cloud deployments, set DATABASE_URL directly (overrides component-level vars)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: enables LLM explanations on GET /recommend/{user_id}/explain
# Get a free key at https://aistudio.google.com
# GEMINI_API_KEY=your_key_here
